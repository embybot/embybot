msgstr "✅ Solicitud de actualización enviada a Emby para: \"{item_name}\". El proceso se ejecutará en segundo plano. Por favor, compruebe los resultados en Emby más tarde."

msgid "❌ Failed to send refresh request for \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ No se pudo enviar la solicitud de actualización para \"{item_name}\" (ID: {item_id}). Código de estado: {code}, Respuesta del servidor: {text}"

