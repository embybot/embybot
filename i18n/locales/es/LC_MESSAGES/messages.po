msgid "❌ Failed to delete \"{item_name}\": Could not obtain a valid user Access Token from the Emby server. Please check the username and password in config.yaml."
msgstr "❌ No se pudo eliminar \"{item_name}\": No se pudo obtener un Token de Acceso de usuario válido del servidor de Emby. Por favor, compruebe el nombre de usuario y la contraseña en config.yaml."

