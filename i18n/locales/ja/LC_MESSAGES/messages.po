msgstr "✅ アイテム「{item_name}」がEmbyライブラリから正常に削除されました。"

msgid "❌ Failed to delete Emby item \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Embyアイテム「{item_name}」(ID: {item_id})の削除に失敗しました。ステータスコード: {code}, サーバーレスポンス: {text}"

msgid "👤 Querying Emby user by username '{username}'..."
msgstr "👤 ユーザー名'{username}'でEmbyユーザーを検索中..."

msgid "Emby server configuration is incomplete."
msgstr "Embyサーバーの設定が不完全です。"

