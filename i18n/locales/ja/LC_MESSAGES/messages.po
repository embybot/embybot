msgstr "❌ {api_name} APIリクエスト失敗 (試行 {attempt})、ステータスコード: {code}, レスポンス: {response}"

msgid "❌ Network error on {api_name} API request (Attempt {attempt}), URL: {url}, Error: {error}"
msgstr "❌ {api_name} APIリクエストでネットワークエラーが発生しました (試行 {attempt})、URL: {url}, エラー: {error}"

