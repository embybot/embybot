msgstr "📜 Ottenimento delle informazioni complete per l'ID utente {id} per estrarre la policy..."

msgid "Failed to get user policy: Policy object not found in the returned user data."
msgstr "Impossibile ottenere la policy utente: oggetto Policy non trovato nei dati utente restituiti."

msgid "Failed to get user policy: Could not parse user information returned by the Emby server."
msgstr "Impossibile ottenere la policy utente: impossibile analizzare le informazioni utente restituite dal server Emby."

msgid "Failed to get user policy: Could not get user information from the Emby API (please check if template_user_id is correct)."
msgstr "Impossibile ottenere la policy utente: impossibile ottenere le informazioni utente dall'API di Emby (controlla se template_user_id è corretto)."

msgid "🔑 Setting a new password for User ID {id}..."
msgstr "🔑 Impostazione di una nuova password per l'ID utente {id}..."

msgid "🗑️ Deleting User ID: {id}"
