msgstr "❌ Errore di rete durante l'ottenimento del token di accesso: {error}"

msgid "🔎 Requesting scan for Emby item ID: {id}, Name: {name}"
msgstr "🔎 Richiesta di scansione per l'elemento Emby ID: {id}, Nome: {name}"

