msgstr "❌ Errore del server {api_name} {code}, verrà effettuato un nuovo tentativo. Errore: {error_text}"

msgid "❌ {api_name} API request failed (Attempt {attempt}), Status Code: {code}, Response: {response}"
msgstr "❌ Richiesta API a {api_name} fallita (Tentativo {attempt}), Codice di stato: {code}, Risposta: {response}"

msgid "❌ Network error on {api_name} API request (Attempt {attempt}), URL: {url}, Error: {error}"
msgstr "❌ Errore di rete durante la richiesta API a {api_name} (Tentativo {attempt}), URL: {url}, Errore: {error}"

msgid "❌ {api_name} API request failed, max retries reached ({max_retries}), URL: {url}"
msgstr "❌ Richiesta API a {api_name} fallita, raggiunto il numero massimo di tentativi ({max_retries}), URL: {url}"

msgid "🔑 Getting Emby Access Token using username/password..."
msgstr "🔑 Ottenimento del token di accesso Emby tramite nome utente/password..."

