msgstr "❌ Creazione fallita: il nome utente '{username}' esiste già."

msgid "❌ Creation failed: Could not get the configuration of the template user (ID: {id}). Error: {error}"
msgstr "❌ Creazione fallita: impossibile ottenere la configurazione dell'utente modello (ID: {id}). Errore: {error}"

