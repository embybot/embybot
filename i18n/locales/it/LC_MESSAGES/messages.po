msgstr "✅ Token di accesso ottenuto con successo."

msgid "❌ Failed to get Access Token. Status Code: {code}, Response: {text}"
msgstr "❌ Impossibile ottenere il token di accesso. Codice di stato: {code}, Risposta: {text}"

