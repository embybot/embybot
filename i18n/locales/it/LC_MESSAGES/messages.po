msgstr "🔎 Richiesta di scansione di tutte le librerie Emby..."

msgid "✅ Request to scan all libraries has been sent to Emby. The task will be executed in the background."
msgstr "✅ La richiesta di scansione di tutte le librerie è stata inviata a Emby. L'attività verrà eseguita in background."

msgid "❌ Failed to send \"Scan All\" request. Status Code: {code}, Response: {text}"
msgstr "❌ Impossibile inviare la richiesta \"Scansiona tutto\". Codice di stato: {code}, Risposta: {text}"

msgid "🔄 Requesting refresh for Emby item ID: {id}, Name: {name}"
msgstr "🔄 Richiesta di aggiornamento per l'elemento Emby ID: {id}, Nome: {name}"

msgid "❌ Refresh failed: Emby server configuration is incomplete."
msgstr "❌ Aggiornamento fallito: la configurazione del server Emby è incompleta."

msgid "✅ Refresh request sent to Emby for: \"{item_name}\". The process will run in the background. Please check the results in Emby later."
msgstr "✅ Richiesta di aggiornamento inviata a Emby per: \"{item_name}\". Il processo verrà eseguito in background. Controlla i risultati su Emby più tardi."

msgid "❌ Failed to send refresh request for \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Impossibile inviare la richiesta di aggiornamento per \"{item_name}\" (ID: {item_id}). Codice di stato: {code}, Risposta del server: {text}"

msgid "🗑️ Requesting to delete item from Emby. ID: {id}, Name: {name}"
msgstr "🗑️ Richiesta di eliminazione dell'elemento da Emby. ID: {id}, Nome: {name}"

msgid "❌ Failed to delete \"{item_name}\": Could not obtain a valid user Access Token from the Emby server. Please check the username and password in config.yaml."
msgstr "❌ Impossibile eliminare \"{item_name}\": impossibile ottenere un token di accesso utente valido dal server Emby. Controlla il nome utente e la password in config.yaml."

msgid "✅ The item \"{item_name}\" has been successfully deleted from the Emby library."
msgstr "✅ L'elemento \"{item_name}\" è stato eliminato con successo dalla libreria Emby."

msgid "❌ Failed to delete Emby item \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Impossibile eliminare l'elemento Emby \"{item_name}\" (ID: {item_id}). Codice di stato: {code}, Risposta del server: {text}"

msgid "👤 Querying Emby user by username '{username}'..."
msgstr "👤 Interrogazione dell'utente Emby per nome utente '{username}'..."

msgid "Emby server configuration is incomplete."
msgstr "La configurazione del server Emby è incompleta."

msgid "✅ Found user '{username}', ID: {id}"
msgstr "✅ Utente '{username}' trovato, ID: {id}"

msgid "Could not find a user with the username '{username}'."
msgstr "Impossibile trovare un utente con il nome utente '{username}'."

msgid "Could not parse the user list response from Emby."
msgstr "Impossibile analizzare la risposta dell'elenco utenti da Emby."

