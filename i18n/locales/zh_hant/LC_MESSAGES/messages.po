msgid ""
"❌ Telegram button callback_data exceeds 64-byte limit: {data} ({length} "
"bytes)"
msgstr ""
"❌ Telegram 按鈕 callback_data 超出 64 位元組限制：{data} ({length} 位元組)"

msgid "⚠️ Exception occurred during local check of reply_markup: {error}"
msgstr "⚠️ 在本地檢查 reply_markup 期間發生異常：{error}"

msgid "Unknown API"
msgstr "未知的 API"

msgid "Telegram"
msgstr "Telegram"

msgid "TMDB"
msgstr "TMDB"

msgid "IP Geolocation"
msgstr "IP 地理位置"

msgid "Emby"
msgstr "Emby"

msgid ""
"🌐 Making {api_name} API request (Attempt {attempt}), URL: {url}, Timeout: "
"{timeout}s"
msgstr ""
"🌐 正在向 {api_name} API 發出請求 (第 {attempt} 次)，URL: {url}，超時: "
"{timeout}秒"

msgid "✅ {api_name} API request successful, Status Code: {code}"
msgstr "✅ {api_name} API 請求成功，狀態碼: {code}"

msgid "ℹ️ Telegram returned an ignorable edit/delete type error, ignoring."
msgstr "ℹ️ Telegram 返回了可忽略的編輯/刪除類型錯誤，已忽略。"

msgid ""
"⏳ Telegram rate limit (429), retrying after {seconds}s. Error: {error_text}"
msgstr ""
"⏳ 觸發 Telegram 速率限制 (429)，將在 {seconds} 秒後重試。錯誤: {error_text}"

msgid "❌ {api_name} server error {code}, will retry. Error: {error_text}"
msgstr "❌ {api_name} 伺服器錯誤 {code}，將重試。錯誤: {error_text}"

msgid ""
"❌ {api_name} API request failed (Attempt {attempt}), Status Code: {code}, "
"Response: {response}"
msgstr ""
"❌ {api_name} API 請求失敗 (第 {attempt} 次)，狀態碼: {code}，回應: {response}"

msgid ""
"❌ Network error on {api_name} API request (Attempt {attempt}), URL: {url}, "
"Error: {error}"
msgstr ""
"❌ 向 {api_name} API 發出請求時發生網路錯誤 (第 {attempt} 次)，URL: {url}，錯"
"誤: {error}"

msgid ""
"❌ {api_name} API request failed, max retries reached ({max_retries}), URL: "
"{url}"
msgstr ""
"❌ {api_name} API 請求失敗，已達最大重試次數 ({max_retries})，URL: {url}"

msgid "🔑 Getting Emby Access Token using username/password..."
msgstr "🔑 正在使用使用者名稱/密碼獲取 Emby 存取權杖..."

msgid ""
"❌ Missing Emby username or password configuration required to get a token."
msgstr "❌ 缺少獲取權杖所需的 Emby 使用者名稱或密碼設定。"

msgid "✅ Successfully obtained Access Token."
msgstr "✅ 成功獲取存取權杖。"

msgid "❌ Failed to get Access Token. Status Code: {code}, Response: {text}"
msgstr "❌ 獲取存取權杖失敗。狀態碼: {code}，回應: {text}"

msgid "❌ Network error while getting Access Token: {error}"
msgstr "❌ 獲取存取權杖時發生網路錯誤: {error}"

msgid "🔎 Requesting scan for Emby item ID: {id}, Name: {name}"
msgstr "🔎 請求掃描 Emby 項目 ID: {id}，名稱: {name}"

msgid "❌ Scan failed: Emby server configuration is incomplete."
msgstr "❌ 掃描失敗：Emby 伺服器設定不完整。"

msgid ""
"✅ Scan request sent to Emby for: \"{item_name}\". The process will run in "
"the background. Please check the results in Emby later."
msgstr ""
"✅ 已向 Emby 發送掃描請求： 「{item_name}」。該過程將在背景執行，請稍後在 "
"Emby 中檢查結果。"

msgid ""
"❌ Failed to send scan request for \"{item_name}\" (ID: {item_id}). Status "
"Code: {code}, Server Response: {text}"
msgstr ""
"❌ 發送掃描請求失敗： 「{item_name}」 (ID: {item_id})。狀態碼: {code}，伺服器"
"回應: {text}"

msgid "🔎 Requesting to scan all Emby libraries..."
msgstr "🔎 請求掃描所有 Emby 媒體庫..."

msgid ""
"✅ Request to scan all libraries has been sent to Emby. The task will be "
"executed in the background."
msgstr "✅ 掃描所有媒體庫的請求已發送至 Emby。任務將在背景執行。"

msgid ""
"❌ Failed to send \"Scan All\" request. Status Code: {code}, Response: {text}"
msgstr "❌ 發送「掃描全部」請求失敗。狀態碼: {code}，回應: {text}"

msgid "🔄 Requesting refresh for Emby item ID: {id}, Name: {name}"
msgstr "🔄 請求刷新 Emby 項目 ID: {id}，名稱: {name}"

msgid "❌ Refresh failed: Emby server configuration is incomplete."
msgstr "❌ 刷新失敗：Emby 伺服器設定不完整。"

msgid ""
"✅ Refresh request sent to Emby for: \"{item_name}\". The process will run in "
"the background. Please check the results in Emby later."
msgstr ""
"✅ 已向 Emby 發送刷新請求： 「{item_name}」。該過程將在背景執行，請稍後在 "
"Emby 中檢查結果。"

msgid ""
"❌ Failed to send refresh request for \"{item_name}\" (ID: {item_id}). Status "
"Code: {code}, Server Response: {text}"
msgstr ""
"❌ 發送刷新請求失敗： 「{item_name}」 (ID: {item_id})。狀態碼: {code}，伺服器"
"回應: {text}"

msgid "🗑️ Requesting to delete item from Emby. ID: {id}, Name: {name}"
msgstr "🗑️ 請求從 Emby 刪除項目。 ID: {id}，名稱: {name}"

msgid ""
"❌ Failed to delete \"{item_name}\": Could not obtain a valid user Access "
"Token from the Emby server. Please check the username and password in "
"config.yaml."
msgstr ""
"❌ 刪除「{item_name}」失敗：無法從 Emby 伺服器獲取有效的使用者存取權杖。請檢"
"查 config.yaml 中的使用者名稱和密碼。"

msgid ""
"✅ The item \"{item_name}\" has been successfully deleted from the Emby "
"library."
msgstr "✅ 項目「{item_name}」已成功從 Emby 媒體庫中刪除。"

msgid ""
"❌ Failed to delete Emby item \"{item_name}\" (ID: {item_id}). Status Code: "
"{code}, Server Response: {text}"
msgstr ""
"❌ 刪除 Emby 項目「{item_name}」 (ID: {item_id}) 失敗。狀態碼: {code}，伺服器"
"回應: {text}"

msgid "👤 Querying Emby user by username '{username}'..."
msgstr "👤 正在按使用者名稱 '{username}' 查詢 Emby 使用者..."

msgid "Emby server configuration is incomplete."
msgstr "Emby 伺服器設定不完整。"

msgid "✅ Found user '{username}', ID: {id}"
msgstr "✅ 找到使用者 '{username}'，ID: {id}"

msgid "Could not find a user with the username '{username}'."
msgstr "找不到用戶名為 '{username}' 的使用者。"

msgid "Could not parse the user list response from Emby."
msgstr "無法解析來自 Emby 的使用者列表回應。"

msgid "Failed to get user list from Emby API."
msgstr "從 Emby API 獲取使用者列表失敗。"

msgid "📜 Getting full info for User ID {id} to extract policy..."
msgstr "📜 正在獲取使用者 ID {id} 的完整資訊以提取策略..."

msgid ""
"Failed to get user policy: Policy object not found in the returned user data."
msgstr "獲取使用者策略失敗：在返回的使用者資料中找不到策略物件。"

msgid ""
"Failed to get user policy: Could not parse user information returned by the "
"Emby server."
msgstr "獲取使用者策略失敗：無法解析 Emby 伺服器返回的使用者資訊。"

msgid ""
"Failed to get user policy: Could not get user information from the Emby API "
"(please check if template_user_id is correct)."
msgstr ""
"獲取使用者策略失敗：無法從 Emby API 獲取使用者資訊（請檢查 template_user_id 是"
"否正確）。"

msgid "🔑 Setting a new password for User ID {id}..."
msgstr "🔑 正在為使用者 ID {id} 設定新密碼..."

msgid "🗑️ Deleting User ID: {id}"
msgstr "🗑️ 正在刪除使用者 ID: {id}"

msgid "✏️ Renaming username for User ID {id} to '{new_username}'..."
msgstr "✏️ 正在將使用者 ID {id} 的使用者名稱更改為 '{new_username}'..."

msgid ""
"❌ Rename failed: Username '{new_username}' is already taken by another user."
msgstr "❌ 重命名失敗：使用者名稱 '{new_username}' 已被其他使用者佔用。"

msgid "❌ Rename failed: Could not get the details of the current user."
msgstr "❌ 重命名失敗：無法獲取目前使用者的詳細資訊。"

msgid "❌ Rename failed: Could not parse the current user's information."
msgstr "❌ 重命名失敗：無法解析目前使用者的資訊。"

msgid "✅ Username has been successfully changed to '{new_username}'."
msgstr "✅ 使用者名稱已成功更改為 '{new_username}'。"

msgid "❌ Failed to rename username, the server did not respond successfully."
msgstr "❌ 重命名使用者名稱失敗，伺服器未成功回應。"

msgid ""
"❌ Creation failed: `template_user_id` is not set in the configuration file."
msgstr "❌ 建立失敗：設定檔中未設定 `template_user_id`。"

msgid "❌ Creation failed: Username '{username}' already exists."
msgstr "❌ 建立失敗：使用者名稱 '{username}' 已存在。"

msgid ""
"❌ Creation failed: Could not get the configuration of the template user (ID: "
"{id}). Error: {error}"
msgstr "❌ 建立失敗：無法獲取範本使用者的設定 (ID: {id})。錯誤: {error}"

msgid "✅ Successfully got the policy for template user {id}."
msgstr "✅ 成功獲取範本使用者 {id} 的策略。"

msgid "➕ Creating new user: {username}..."
msgstr "➕ 正在建立新使用者: {username}..."

msgid "❌ Creation failed: Error when calling the Emby API to create a user."
msgstr "❌ 建立失敗：呼叫 Emby API 建立使用者時發生錯誤。"

msgid "✅ User '{username}' has been created, new ID: {id}."
msgstr "✅ 使用者 '{username}' 已建立，新的 ID 為: {id}。"

msgid ""
"❌ Creation failed: Could not parse new user information from the Emby API "
"response."
msgstr "❌ 建立失敗：無法從 Emby API 回應中解析新使用者資訊。"

msgid "📜 Applying template policy for new user {id}..."
msgstr "📜 正在為新使用者 {id} 應用範本策略..."

msgid ""
"❌ Creation failed: Error applying policy for the new user, operation has "
"been rolled back."
msgstr "❌ 建立失敗：為新使用者應用策略時出錯，操作已復原。"

msgid "✅ Policy applied successfully."
msgstr "✅ 策略應用成功。"

msgid "🔑 Setting password for new user {id}..."
msgstr "🔑 正在為新使用者 {id} 設定密碼..."

msgid ""
"❌ Creation failed: Error setting password for the new user, operation has "
"been rolled back."
msgstr "❌ 建立失敗：為新使用者設定密碼時出錯，操作已復原。"

msgid "✅ Password set successfully."
msgstr "✅ 密碼設定成功。"

msgid ""
"✅ Successfully created user '{username}', configuration cloned from template "
"user."
msgstr "✅ 成功建立使用者 '{username}'，設定已從範本使用者複製。"

msgid "ℹ️ Getting Emby user list from cache."
msgstr "ℹ️ 從快取獲取 Emby 使用者列表。"

msgid "🔑 Getting full user list from Emby API..."
msgstr "🔑 正在從 Emby API 獲取完整使用者列表..."

msgid "❌ Missing Emby server configuration required to get user list."
msgstr "❌ 缺少獲取使用者列表所需的 Emby 伺服器設定。"

msgid "✅ Successfully retrieved and cached {count} usernames."
msgstr "✅ 成功獲取並快取了 {count} 個使用者名稱。"

msgid "❌ Failed to get Emby user list: Could not parse server response."
msgstr "❌ 獲取 Emby 使用者列表失敗：無法解析伺服器回應。"

msgid "❌ Failed to get Emby user list."
msgstr "❌ 獲取 Emby 使用者列表失敗。"

msgid "ℹ️ Querying active Emby sessions."
msgstr "ℹ️ 正在查詢有效的 Emby 工作階段。"

msgid "❌ Missing Emby server configuration, cannot query sessions."
msgstr "❌ 缺少 Emby 伺服器設定，無法查詢工作階段。"

msgid "✅ Found {count} active sessions."
msgstr "✅ 找到 {count} 個有效的工作階段。"

msgid "❌ Failed to query active sessions: Could not parse server response."
msgstr "❌ 查詢有效工作階段失敗：無法解析伺服器回應。"

msgid "🛑 Attempting to stop playback session: {id}"
msgstr "🛑 正在嘗試停止播放工作階段: {id}"

msgid "❌ Failed to stop session: Emby server configuration is incomplete."
msgstr "❌ 停止工作階段失敗：Emby 伺服器設定不完整。"

msgid "✅ Playback session {id} has been stopped successfully."
msgstr "✅ 播放工作階段 {id} 已成功停止。"

msgid "❌ Failed to stop playback session {id}."
msgstr "❌ 停止播放工作階段 {id} 失敗。"

msgid "✉️ Sending message to session {id}."
msgstr "✉️ 正在向工作階段 {id} 發送訊息。"

msgid "❌ Failed to send message: Emby server configuration is incomplete."
msgstr "❌ 發送訊息失敗：Emby 伺服器設定不完整。"

msgid "Message from administrator"
msgstr "來自管理員的訊息"

msgid "✅ Message sent successfully to session {id}."
msgstr "✅ 訊息已成功發送至工作階段 {id}。"

msgid "❌ Failed to send message to session {id}."
msgstr "❌ 向工作階段 {id} 發送訊息失敗。"

msgid "ℹ️ Getting resolution for item {id}."
msgstr "ℹ️ 正在獲取項目 {id} 的解析度。"

msgid "❌ Failed to get media source info for item {id}."
msgstr "❌ 獲取項目 {id} 的媒體來源資訊失敗。"

msgid "Unknown resolution"
msgstr "未知的解析度"

msgid "❌ Media source for item {id} is empty."
msgstr "❌ 項目 {id} 的媒體來源為空。"

msgid "✅ Got resolution for item {id}: {w}x{h}"
msgstr "✅ 已獲取項目 {id} 的解析度: {w}x{h}"

msgid "⚠️ No video stream found in item {id}."
msgstr "⚠️ 在項目 {id} 中未找到視訊串流。"

msgid "❌ Error parsing media source info for item {id}."
msgstr "❌ 解析項目 {id} 的媒體來源資訊時出錯。"

msgid "🗂️ Getting Emby library list..."
msgstr "🗂️ 正在獲取 Emby 媒體庫列表..."

msgid "Could not find any media libraries."
msgstr "找不到任何媒體庫。"

msgid "✅ Successfully retrieved {count} media libraries."
msgstr "✅ 成功獲取 {count} 個媒體庫。"

msgid "Failed to parse media library list: {error}"
msgstr "解析媒體庫列表失敗: {error}"

msgid "Failed to get media library list from Emby API."
msgstr "從 Emby API 獲取媒體庫列表失敗。"

msgid "ℹ️ Getting latest episode information for series {id}."
msgstr "ℹ️ 正在獲取劇集 {id} 的最新分集資訊。"

msgid "✅ Got latest episode: S{s}E{e}"
msgstr "✅ 已獲取最新分集: S{s}E{e}"

msgid "ℹ️ Querying for exact item info of series {id} S{s:02d}E{e:02d}."
msgstr "ℹ️ 正在查詢劇集 {id} S{s:02d}E{e:02d} 的精確項目資訊。"

msgid "✅ Exact match successful, Item ID: {id}"
msgstr "✅ 精確匹配成功，項目 ID: {id}"

msgid "❌ Emby API could not find S{s:02d}E{e:02d}."
msgstr "❌ Emby API 找不到 S{s:02d}E{e:02d}。"

msgid "ℹ️ Looking for any episode in season {num} as a spec reference..."
msgstr "ℹ️ 正在第 {num} 季中尋找任一分集作為規格參考..."

msgid "✅ Found reference episode in season {num}, ID: {id}"
msgstr "✅ 在第 {num} 季中找到參考分集，ID: {id}"

msgid "❌ Could not find any episodes in season {num}."
msgstr "❌ 在第 {num} 季中找不到任何分集。"

msgid "ℹ️ Getting media stream info for item {id}."
msgstr "ℹ️ 正在獲取項目 {id} 的媒體串流資訊。"

msgid "✅ Got media stream info for item {id}."
msgstr "✅ 已獲取項目 {id} 的媒體串流資訊。"

msgid "ℹ️ Getting season specs for series {id}."
msgstr "ℹ️ 正在獲取劇集 {id} 的季度規格。"

msgid "Error: This feature requires an Emby User ID to be configured"
msgstr "錯誤：此功能需要設定 Emby 使用者 ID"

msgid "Failed to query season list"
msgstr "查詢季度列表失敗"

msgid "No seasons found"
msgstr "未找到季度"

msgid "ℹ️ Querying episodes for season {num} ({id})."
msgstr "ℹ️ 正在查詢第 {num} 季 ({id}) 的分集。"

msgid "Error parsing season information"
msgstr "解析季度資訊時出錯"

msgid "🟡 Emby season S{num:02d} not found"
msgstr "🟡 未找到 Emby 季度 S{num:02d}"

msgid "No seasons were deleted."
msgstr "沒有季度被刪除。"

msgid "❌ Failed to fetch episode list for Emby season S{num:02d}"
msgstr "❌ 獲取 Emby 季度 S{num:02d} 的分集列表失敗"

msgid "❌ Failed to parse episode list for Emby season S{num:02d}"
msgstr "❌ 解析 Emby 季度 S{num:02d} 的分集列表失敗"

msgid "🟡 Emby item S{s:02d}E{e:02d} not found"
msgstr "🟡 未找到 Emby 項目 S{s:02d}E{e:02d}"

msgid "No episodes were deleted."
msgstr "沒有分集被刪除。"

msgid "Unknown location"
msgstr "未知位置"

msgid "✅ Successfully got geolocation for IP ({ip}) from Baidu API: {location}"
msgstr "✅ 成功從百度 API 獲取 IP ({ip}) 的地理位置: {location}"

msgid "❌ Error parsing Baidu API response. IP: {ip}, Error: {error}"
msgstr "❌ 解析百度 API 回應時出錯。 IP: {ip}，錯誤: {error}"

msgid ""
"❌ IP138 API Error: 'ip_api_token_ip138' is not configured in config.yaml."
msgstr "❌ IP138 API 錯誤：'ip_api_token_ip138' 未在 config.yaml 中設定。"

msgid "Unknown location (Token missing)"
msgstr "未知位置 (缺少權杖)"

msgid "China"
msgstr "中國"

msgid "❌ Error parsing IP138 API response. IP: {ip}, Error: {error}"
msgstr "❌ 解析 IP138 API 回應時出錯。 IP: {ip}，錯誤: {error}"

msgid "❌ Error parsing PCOnline API response. IP: {ip}, Error: {error}"
msgstr "❌ 解析 PCOnline API 回應時出錯。 IP: {ip}，錯誤: {error}"

msgid "❌ Error parsing Vore API response. IP: {ip}, Error: {error}"
msgstr "❌ 解析 Vore API 回應時出錯。 IP: {ip}，錯誤: {error}"

msgid "Telecom"
msgstr "電信"

msgid "Unicom"
msgstr "聯通"

msgid "Mobile"
msgstr "移動"

msgid "Broadcasting"
msgstr "廣電"

msgid "❌ Error parsing IP-API.com response. IP: {ip}, Error: {error}"
msgstr "❌ 解析 IP-API.com 回應時出錯。 IP: {ip}，錯誤: {error}"

msgid "LAN"
msgstr "內網"

msgid "🌍 Querying IP: {ip} using {provider} API"
msgstr "🌍 正在使用 {provider} API 查詢 IP: {ip}"

msgid "🔍 Querying details for TMDB ID: {id}"
msgstr "🔍 正在查詢 TMDB ID 的詳細資訊: {id}"

msgid "✅ Found a match in TMDB: {title} (Type: {type})"
msgstr "✅ 在 TMDB 中找到匹配項: {title} (類型: {type})"

msgid "❌ Nothing found in TMDB with ID {id}."
msgstr "❌ 在 TMDB 中找不到 ID 為 {id} 的項目。"

msgid "Any year"
msgstr "任何年份"

msgid "🔍 Performing multi-search on TMDB: {title} ({year})"
msgstr "🔍 正在 TMDB 上執行多重搜尋: {title} ({year})"

msgid "✅ TMDB multi-search found {count} unique results."
msgstr "✅ TMDB 多重搜尋找到 {count} 個獨立結果。"

msgid "🔍 Searching TMDB: {title} ({year})"
msgstr "🔍 正在搜尋 TMDB: {title} ({year})"

msgid "❌ TMDB found no matching results."
msgstr "❌ TMDB 未找到匹配結果。"

msgid "✅ Found exact match: {title}, ID: {id}"
msgstr "✅ 找到精確匹配: {title}，ID: {id}"

msgid ""
"⚠️ No exact match found, returning the most popular result: {title}, ID: {id}"
msgstr "⚠️ 未找到精確匹配，返回最熱門的結果: {title}，ID: {id}"

msgid "❌ TMDB search failed"
