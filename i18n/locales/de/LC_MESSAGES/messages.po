msgstr "🔎 Fordere Scan aller Emby-Bibliotheken an..."

msgid "✅ Request to scan all libraries has been sent to Emby. The task will be executed in the background."
msgstr "✅ Die Anforderung, alle Bibliotheken zu scannen, wurde an Emby gesendet. die Aufgabe wird im Hintergrund ausgeführt."

msgid "❌ Failed to send \"Scan All\" request. Status Code: {code}, Response: {text}"
msgstr "❌ Senden der Anfrage \"Alles scannen\" fehlgeschlagen. Statuscode: {code}, Antwort: {text}"

msgid "🔄 Requesting refresh for Emby item ID: {id}, Name: {name}"
msgstr "🔄 Fordere Aktualisierung für Emby-Element-ID an: {id}, Name: {name}"

msgid "❌ Refresh failed: Emby server configuration is incomplete."
msgstr "❌ Aktualisierung fehlgeschlagen: Die Konfiguration des Emby-Servers ist unvollständig."

