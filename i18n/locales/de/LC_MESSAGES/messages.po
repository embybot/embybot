msgstr "✅ Zugriffstoken erfolgreich erhalten."

msgid "❌ Failed to get Access Token. Status Code: {code}, Response: {text}"
msgstr "❌ Zugriffstoken konnte nicht abgerufen werden. Statuscode: {code}, Antwort: {text}"

