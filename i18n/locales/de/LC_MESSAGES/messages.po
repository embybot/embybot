msgstr "✅ Aktualisierungsanforderung für \"{item_name}\" an Emby gesendet. Der Vorgang wird im Hintergrund ausgeführt. Bitte überprüfen Sie die Ergebnisse später in Emby."

msgid "❌ Failed to send refresh request for \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Senden der Aktualisierungsanforderung für \"{item_name}\" (ID: {item_id}) fehlgeschlagen. Statuscode: {code}, Serverantwort: {text}"

msgid "🗑️ Requesting to delete item from Emby. ID: {id}, Name: {name}"
msgstr "🗑️ Fordere Löschung des Elements aus Emby an. ID: {id}, Name: {name}"

msgid "❌ Failed to delete \"{item_name}\": Could not obtain a valid user Access Token from the Emby server. Please check the username and password in config.yaml."
msgstr "❌ Löschen von \"{item_name}\" fehlgeschlagen: Konnte kein gültiges Benutzer-Zugriffstoken vom Emby-Server erhalten. Bitte überprüfen Sie den Benutzernamen und das Passwort in config.yaml."

msgid "✅ The item \"{item_name}\" has been successfully deleted from the Emby library."
msgstr "✅ Das Element \"{item_name}\" wurde erfolgreich aus der Emby-Bibliothek gelöscht."

msgid "❌ Failed to delete Emby item \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Löschen des Emby-Elements \"{item_name}\" (ID: {item_id}) fehlgeschlagen. Statuscode: {code}, Serverantwort: {text}"

msgid "👤 Querying Emby user by username '{username}'..."
msgstr "👤 Frage Emby-Benutzer nach Benutzername '{username}' ab..."

msgid "Emby server configuration is incomplete."
msgstr "Die Konfiguration des Emby-Servers ist unvollständig."

msgid "✅ Found user '{username}', ID: {id}"
msgstr "✅ Benutzer '{username}' gefunden, ID: {id}"

