msgstr "❌ API-Anfrage an {api_name} fehlgeschlagen, maximale Wiederholungsversuche erreicht ({max_retries}), URL: {url}"

msgid "🔑 Getting Emby Access Token using username/password..."
msgstr "🔑 Rufe Emby-Zugriffstoken mit Benutzername/Passwort ab..."

