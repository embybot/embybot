msgid "❌ Telegram button callback_data exceeds 64-byte limit: {data} ({length} bytes)"
msgstr "❌ callback_data кнопки Telegram превышает лимит в 64 байта: {data} ({length} байт)"

msgid "⚠️ Exception occurred during local check of reply_markup: {error}"
msgstr "⚠️ Произошло исключение при локальной проверке reply_markup: {error}"

msgid "Unknown API"
msgstr "Неизвестный API"

msgid "Telegram"
msgstr "Telegram"

msgid "TMDB"
msgstr "TMDB"

msgid "IP Geolocation"
msgstr "IP Геолокация"

msgid "Emby"
msgstr "Emby"

msgid "🌐 Making {api_name} API request (Attempt {attempt}), URL: {url}, Timeout: {timeout}s"
msgstr "🌐 Выполняется запрос к {api_name} API (попытка {attempt}), URL: {url}, таймаут: {timeout}с"

msgid "✅ {api_name} API request successful, Status Code: {code}"
msgstr "✅ Запрос к {api_name} API успешно выполнен, код состояния: {code}"

msgid "ℹ️ Telegram returned an ignorable edit/delete type error, ignoring."
msgstr "ℹ️ Telegram вернул игнорируемую ошибку типа редактирования/удаления, игнорируется."

msgid "⏳ Telegram rate limit (429), retrying after {seconds}s. Error: {error_text}"
msgstr "⏳ Ограничение скорости Telegram (429), повторная попытка через {seconds}с. Ошибка: {error_text}"

msgid "❌ {api_name} server error {code}, will retry. Error: {error_text}"
msgstr "❌ Ошибка сервера {api_name} {code}, будет повторная попытка. Ошибка: {error_text}"

msgid "❌ {api_name} API request failed (Attempt {attempt}), Status Code: {code}, Response: {response}"
msgstr "❌ Запрос к {api_name} API не удался (попытка {attempt}), код состояния: {code}, ответ: {response}"

msgid "❌ Network error on {api_name} API request (Attempt {attempt}), URL: {url}, Error: {error}"
msgstr "❌ Сетевая ошибка при запросе к {api_name} API (попытка {attempt}), URL: {url}, ошибка: {error}"

msgid "❌ {api_name} API request failed, max retries reached ({max_retries}), URL: {url}"
msgstr "❌ Запрос к {api_name} API не удался, достигнуто максимальное количество повторов ({max_retries}), URL: {url}"

msgid "🔑 Getting Emby Access Token using username/password..."
msgstr "🔑 Получение токена доступа Emby с использованием имени пользователя/пароля..."

msgid "❌ Missing Emby username or password configuration required to get a token."
msgstr "❌ Отсутствует конфигурация имени пользователя или пароля Emby, необходимая для получения токена."

msgid "✅ Successfully obtained Access Token."
msgstr "✅ Токен доступа успешно получен."

msgid "❌ Failed to get Access Token. Status Code: {code}, Response: {text}"
msgstr "❌ Не удалось получить токен доступа. Код состояния: {code}, ответ: {text}"

msgid "❌ Network error while getting Access Token: {error}"
msgstr "❌ Сетевая ошибка при получении токена доступа: {error}"

msgid "🔎 Requesting scan for Emby item ID: {id}, Name: {name}"
msgstr "🔎 Запрос на сканирование элемента Emby ID: {id}, имя: {name}"

msgid "❌ Scan failed: Emby server configuration is incomplete."
msgstr "❌ Сканирование не удалось: конфигурация сервера Emby не завершена."

msgid "✅ Scan request sent to Emby for: \"{item_name}\". The process will run in the background. Please check the results in Emby later."
msgstr "✅ Запрос на сканирование отправлен в Emby для: \"{item_name}\". Процесс будет выполняться в фоновом режиме. Пожалуйста, проверьте результаты в Emby позже."

msgid "❌ Failed to send scan request for \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Не удалось отправить запрос на сканирование для \"{item_name}\" (ID: {item_id}). Код состояния: {code}, ответ сервера: {text}"

msgid "🔎 Requesting to scan all Emby libraries..."
msgstr "🔎 Запрос на сканирование всех библиотек Emby..."

msgid "✅ Request to scan all libraries has been sent to Emby. The task will be executed in the background."
msgstr "✅ Запрос на сканирование всех библиотек был отправлен в Emby. Задача будет выполнена в фоновом режиме."

msgid "❌ Failed to send \"Scan All\" request. Status Code: {code}, Response: {text}"
msgstr "❌ Не удалось отправить запрос \"Сканировать все\". Код состояния: {code}, ответ: {text}"

msgid "🔄 Requesting refresh for Emby item ID: {id}, Name: {name}"
msgstr "🔄 Запрос на обновление элемента Emby ID: {id}, имя: {name}"

msgid "❌ Refresh failed: Emby server configuration is incomplete."
msgstr "❌ Обновление не удалось: конфигурация сервера Emby не завершена."

msgid "✅ Refresh request sent to Emby for: \"{item_name}\". The process will run in the background. Please check the results in Emby later."
msgstr "✅ Запрос на обновление отправлен в Emby для: \"{item_name}\". Процесс будет выполняться в фоновом режиме. Пожалуйста, проверьте результаты в Emby позже."

msgid "❌ Failed to send refresh request for \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Не удалось отправить запрос на обновление для \"{item_name}\" (ID: {item_id}). Код состояния: {code}, ответ сервера: {text}"

msgid "🗑️ Requesting to delete item from Emby. ID: {id}, Name: {name}"
msgstr "🗑️ Запрос на удаление элемента из Emby. ID: {id}, имя: {name}"

msgid "❌ Failed to delete \"{item_name}\": Could not obtain a valid user Access Token from the Emby server. Please check the username and password in config.yaml."
msgstr "❌ Не удалось удалить \"{item_name}\": не удалось получить действительный токен доступа пользователя с сервера Emby. Пожалуйста, проверьте имя пользователя и пароль в config.yaml."

msgid "✅ The item \"{item_name}\" has been successfully deleted from the Emby library."
msgstr "✅ Элемент \"{item_name}\" был успешно удален из библиотеки Emby."

msgid "❌ Failed to delete Emby item \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Не удалось удалить элемент Emby \"{item_name}\" (ID: {item_id}). Код состояния: {code}, ответ сервера: {text}"

msgid "👤 Querying Emby user by username '{username}'..."
msgstr "👤 Запрос пользователя Emby по имени пользователя '{username}'..."

msgid "Emby server configuration is incomplete."
msgstr "Конфигурация сервера Emby не завершена."

msgid "✅ Found user '{username}', ID: {id}"
msgstr "✅ Найден пользователь '{username}', ID: {id}"

msgid "Could not find a user with the username '{username}'."
msgstr "Не удалось найти пользователя с именем '{username}'."

msgid "Could not parse the user list response from Emby."
msgstr "Не удалось разобрать ответ со списком пользователей от Emby."

msgid "Failed to get user list from Emby API."
msgstr "Не удалось получить список пользователей из Emby API."

msgid "📜 Getting full info for User ID {id} to extract policy..."
msgstr "📜 Получение полной информации для User ID {id} для извлечения политики..."

msgid "Failed to get user policy: Policy object not found in the returned user data."
msgstr "Не удалось получить политику пользователя: объект политики не найден в возвращенных данных пользователя."

msgid "Failed to get user policy: Could not parse user information returned by the Emby server."
msgstr "Не удалось получить политику пользователя: не удалось разобрать информацию о пользователе, возвращенную сервером Emby."

msgid "Failed to get user policy: Could not get user information from the Emby API (please check if template_user_id is correct)."
msgstr "Не удалось получить политику пользователя: не удалось получить информацию о пользователе из API Emby (пожалуйста, проверьте правильность template_user_id)."

msgid "🔑 Setting a new password for User ID {id}..."
msgstr "🔑 Установка нового пароля для User ID {id}..."

msgid "🗑️ Deleting User ID: {id}"
msgstr "🗑️ Удаление User ID: {id}"

msgid "✏️ Renaming username for User ID {id} to '{new_username}'..."
msgstr "✏️ Переименование имени пользователя для User ID {id} на '{new_username}'..."

msgid "❌ Rename failed: Username '{new_username}' is already taken by another user."
msgstr "❌ Переименование не удалось: имя пользователя '{new_username}' уже занято другим пользователем."

msgid "❌ Rename failed: Could not get the details of the current user."
msgstr "❌ Переименование не удалось: не удалось получить данные текущего пользователя."

msgid "❌ Rename failed: Could not parse the current user's information."
msgstr "❌ Переименование не удалось: не удалось разобрать информацию о текущем пользователе."

msgid "✅ Username has been successfully changed to '{new_username}'."
msgstr "✅ Имя пользователя было успешно изменено на '{new_username}'."

msgid "❌ Failed to rename username, the server did not respond successfully."
msgstr "❌ Не удалось переименовать имя пользователя, сервер не ответил успешно."

msgid "❌ Creation failed: `template_user_id` is not set in the configuration file."
msgstr "❌ Создание не удалось: `template_user_id` не установлен в файле конфигурации."

msgid "❌ Creation failed: Username '{username}' already exists."
msgstr "❌ Создание не удалось: имя пользователя '{username}' уже существует."

msgid "❌ Creation failed: Could not get the configuration of the template user (ID: {id}). Error: {error}"
msgstr "❌ Создание не удалось: не удалось получить конфигурацию пользователя-шаблона (ID: {id}). Ошибка: {error}"

msgid "✅ Successfully got the policy for template user {id}."
msgstr "✅ Политика для пользователя-шаблона {id} успешно получена."

msgid "➕ Creating new user: {username}..."
msgstr "➕ Создание нового пользователя: {username}..."

msgid "❌ Creation failed: Error when calling the Emby API to create a user."
msgstr "❌ Создание не удалось: ошибка при вызове Emby API для создания пользователя."

msgid "✅ User '{username}' has been created, new ID: {id}."
msgstr "✅ Пользователь '{username}' был создан, новый ID: {id}."

msgid "❌ Creation failed: Could not parse new user information from the Emby API response."
msgstr "❌ Создание не удалось: не удалось разобрать информацию о новом пользователе из ответа API Emby."

msgid "📜 Applying template policy for new user {id}..."
msgstr "📜 Применение политики шаблона для нового пользователя {id}..."

msgid "❌ Creation failed: Error applying policy for the new user, operation has been rolled back."
msgstr "❌ Создание не удалось: ошибка применения политики для нового пользователя, операция отменена."

msgid "✅ Policy applied successfully."
msgstr "✅ Политика успешно применена."

msgid "🔑 Setting password for new user {id}..."
msgstr "🔑 Установка пароля для нового пользователя {id}..."

msgid "❌ Creation failed: Error setting password for the new user, operation has been rolled back."
msgstr "❌ Создание не удалось: ошибка установки пароля для нового пользователя, операция отменена."

msgid "✅ Password set successfully."
msgstr "✅ Пароль успешно установлен."

msgid "✅ Successfully created user '{username}', configuration cloned from template user."
msgstr "✅ Успешно создан пользователь '{username}', конфигурация скопирована с пользователя-шаблона."

msgid "ℹ️ Getting Emby user list from cache."
msgstr "ℹ️ Получение списка пользователей Emby из кэша."

msgid "🔑 Getting full user list from Emby API..."
msgstr "🔑 Получение полного списка пользователей из Emby API..."

msgid "❌ Missing Emby server configuration required to get user list."
msgstr "❌ Отсутствует конфигурация сервера Emby, необходимая для получения списка пользователей."

msgid "✅ Successfully retrieved and cached {count} usernames."
msgstr "✅ Успешно получено и кэшировано {count} имен пользователей."

msgid "❌ Failed to get Emby user list: Could not parse server response."
msgstr "❌ Не удалось получить список пользователей Emby: не удалось разобрать ответ сервера."

msgid "❌ Failed to get Emby user list."
msgstr "❌ Не удалось получить список пользователей Emby."

msgid "ℹ️ Querying active Emby sessions."
msgstr "ℹ️ Запрос активных сессий Emby."

msgid "❌ Missing Emby server configuration, cannot query sessions."
msgstr "❌ Отсутствует конфигурация сервера Emby, невозможно запросить сессии."

msgid "✅ Found {count} active sessions."
msgstr "✅ Найдено {count} активных сессий."

msgid "❌ Failed to query active sessions: Could not parse server response."
msgstr "❌ Не удалось запросить активные сессии: не удалось разобрать ответ сервера."

msgid "🛑 Attempting to stop playback session: {id}"
msgstr "🛑 Попытка остановить сеанс воспроизведения: {id}"

msgid "❌ Failed to stop session: Emby server configuration is incomplete."
msgstr "❌ Не удалось остановить сеанс: конфигурация сервера Emby не завершена."

msgid "✅ Playback session {id} has been stopped successfully."
msgstr "✅ Сеанс воспроизведения {id} был успешно остановлен."

msgid "❌ Failed to stop playback session {id}."
msgstr "❌ Не удалось остановить сеанс воспроизведения {id}."

msgid "✉️ Sending message to session {id}."
msgstr "✉️ Отправка сообщения в сессию {id}."

msgid "❌ Failed to send message: Emby server configuration is incomplete."
msgstr "❌ Не удалось отправить сообщение: конфигурация сервера Emby не завершена."

msgid "Message from administrator"
msgstr "Сообщение от администратора"

msgid "✅ Message sent successfully to session {id}."
msgstr "✅ Сообщение успешно отправлено в сессию {id}."

msgid "❌ Failed to send message to session {id}."
msgstr "❌ Не удалось отправить сообщение в сессию {id}."

msgid "ℹ️ Getting resolution for item {id}."
msgstr "ℹ️ Получение разрешения для элемента {id}."

msgid "❌ Failed to get media source info for item {id}."
msgstr "❌ Не удалось получить информацию об источнике медиа для элемента {id}."

msgid "Unknown resolution"
msgstr "Неизвестное разрешение"

msgid "❌ Media source for item {id} is empty."
msgstr "❌ Источник медиа для элемента {id} пуст."

msgid "✅ Got resolution for item {id}: {w}x{h}"
msgstr "✅ Получено разрешение для элемента {id}: {w}x{h}"

msgid "⚠️ No video stream found in item {id}."
msgstr "⚠️ Видеопоток в элементе {id} не найден."

msgid "❌ Error parsing media source info for item {id}."
msgstr "❌ Ошибка разбора информации об источнике медиа для элемента {id}."

msgid "🗂️ Getting Emby library list..."
msgstr "🗂️ Получение списка библиотек Emby..."

msgid "Could not find any media libraries."
msgstr "Не удалось найти ни одной медиатеки."

msgid "✅ Successfully retrieved {count} media libraries."
msgstr "✅ Успешно получено {count} медиатек."

msgid "Failed to parse media library list: {error}"
msgstr "Не удалось разобрать список медиатек: {error}"

msgid "Failed to get media library list from Emby API."
msgstr "Не удалось получить список медиатек из API Emby."

msgid "ℹ️ Getting latest episode information for series {id}."
msgstr "ℹ️ Получение последней информации об эпизоде для сериала {id}."

msgid "✅ Got latest episode: S{s}E{e}"
msgstr "✅ Получен последний эпизод: S{s}E{e}"

msgid "ℹ️ Querying for exact item info of series {id} S{s:02d}E{e:02d}."
msgstr "ℹ️ Запрос точной информации об элементе сериала {id} S{s:02d}E{e:02d}."

msgid "✅ Exact match successful, Item ID: {id}"
msgstr "✅ Точное совпадение успешно, ID элемента: {id}"

msgid "❌ Emby API could not find S{s:02d}E{e:02d}."
msgstr "❌ API Emby не смог найти S{s:02d}E{e:02d}."

msgid "ℹ️ Looking for any episode in season {num} as a spec reference..."
msgstr "ℹ️ Поиск любого эпизода в сезоне {num} в качестве эталона спецификации..."

msgid "✅ Found reference episode in season {num}, ID: {id}"
msgstr "✅ Найден эталонный эпизод в сезоне {num}, ID: {id}"

msgid "❌ Could not find any episodes in season {num}."
msgstr "❌ Не удалось найти ни одного эпизода в сезоне {num}."

msgid "ℹ️ Getting media stream info for item {id}."
msgstr "ℹ️ Получение информации о медиапотоке для элемента {id}."

msgid "✅ Got media stream info for item {id}."
msgstr "✅ Получена информация о медиапотоке для элемента {id}."

msgid "ℹ️ Getting season specs for series {id}."
msgstr "ℹ️ Получение спецификаций сезона для сериала {id}."

msgid "Error: This feature requires an Emby User ID to be configured"
msgstr "Ошибка: для этой функции требуется настроить Emby User ID"

msgid "Failed to query season list"
msgstr "Не удалось запросить список сезонов"

msgid "No seasons found"
msgstr "Сезоны не найдены"

msgid "ℹ️ Querying episodes for season {num} ({id})."
msgstr "ℹ️ Запрос эпизодов для сезона {num} ({id})."

msgid "Error parsing season information"
msgstr "Ошибка разбора информации о сезоне"

msgid "🟡 Emby season S{num:02d} not found"
msgstr "🟡 Сезон Emby S{num:02d} не найден"

msgid "No seasons were deleted."
msgstr "Ни один сезон не был удален."

msgid "❌ Failed to fetch episode list for Emby season S{num:02d}"
msgstr "❌ Не удалось получить список эпизодов для сезона Emby S{num:02d}"

msgid "❌ Failed to parse episode list for Emby season S{num:02d}"
msgstr "❌ Не удалось разобрать список эпизодов для сезона Emby S{num:02d}"

msgid "🟡 Emby item S{s:02d}E{e:02d} not found"
msgstr "🟡 Элемент Emby S{s:02d}E{e:02d} не найден"

msgid "No episodes were deleted."
msgstr "Ни один эпизод не был удален."

msgid "Unknown location"
msgstr "Неизвестное местоположение"

msgid "✅ Successfully got geolocation for IP ({ip}) from Baidu API: {location}"
msgstr "✅ Успешно получена геолокация для IP ({ip}) из Baidu API: {location}"

msgid "❌ Error parsing Baidu API response. IP: {ip}, Error: {error}"
msgstr "❌ Ошибка разбора ответа Baidu API. IP: {ip}, ошибка: {error}"

msgid "❌ IP138 API Error: 'ip_api_token_ip138' is not configured in config.yaml."
msgstr "❌ Ошибка API IP138: 'ip_api_token_ip138' не настроен в config.yaml."

msgid "Unknown location (Token missing)"
msgstr "Неизвестное местоположение (токен отсутствует)"

msgid "China"
msgstr "Китай"

msgid "❌ Error parsing IP138 API response. IP: {ip}, Error: {error}"
msgstr "❌ Ошибка разбора ответа API IP138. IP: {ip}, ошибка: {error}"

msgid "❌ Error parsing PCOnline API response. IP: {ip}, Error: {error}"
msgstr "❌ Ошибка разбора ответа API PCOnline. IP: {ip}, ошибка: {error}"

msgid "❌ Error parsing Vore API response. IP: {ip}, Error: {error}"
msgstr "❌ Ошибка разбора ответа Vore API. IP: {ip}, ошибка: {error}"

msgid "Telecom"
msgstr "Телеком"

msgid "Unicom"
msgstr "Юником"

msgid "Mobile"
msgstr "Мобильный"

msgid "Broadcasting"
msgstr "Вещание"

msgid "❌ Error parsing IP-API.com response. IP: {ip}, Error: {error}"
msgstr "❌ Ошибка разбора ответа IP-API.com. IP: {ip}, ошибка: {error}"

msgid "LAN"
msgstr "ЛВС"

msgid "🌍 Querying IP: {ip} using {provider} API"
msgstr "🌍 Запрос IP: {ip} с использованием API {provider}"

msgid "🔍 Querying details for TMDB ID: {id}"
msgstr "🔍 Запрос подробностей для TMDB ID: {id}"

msgid "✅ Found a match in TMDB: {title} (Type: {type})"
msgstr "✅ Найдено совпадение в TMDB: {title} (тип: {type})"

msgid "❌ Nothing found in TMDB with ID {id}."
msgstr "❌ В TMDB ничего не найдено с ID {id}."

msgid "Any year"
msgstr "Любой год"

msgid "🔍 Performing multi-search on TMDB: {title} ({year})"
msgstr "🔍 Выполнение многократного поиска в TMDB: {title} ({year})"

msgid "✅ TMDB multi-search found {count} unique results."
msgstr "✅ Многократный поиск TMDB нашел {count} уникальных результатов."

msgid "🔍 Searching TMDB: {title} ({year})"
msgstr "🔍 Поиск в TMDB: {title} ({year})"

msgid "❌ TMDB found no matching results."
msgstr "❌ TMDB не нашел совпадающих результатов."

msgid "✅ Found exact match: {title}, ID: {id}"
