msgid "❌ Telegram button callback_data exceeds 64-byte limit: {data} ({length} bytes)"
msgstr "❌ Telegram 버튼의 callback_data가 64바이트 제한을 초과했습니다: {data} ({length} 바이트)"

msgid "⚠️ Exception occurred during local check of reply_markup: {error}"
msgstr "⚠️ reply_markup 로컬 확인 중 예외가 발생했습니다: {error}"

msgid "Unknown API"
msgstr "알 수 없는 API"

msgid "Telegram"
msgstr "Telegram"

msgid "TMDB"
msgstr "TMDB"

msgid "IP Geolocation"
msgstr "IP 지리적 위치"

msgid "Emby"
msgstr "Emby"

msgid "🌐 Making {api_name} API request (Attempt {attempt}), URL: {url}, Timeout: {timeout}s"
msgstr "🌐 {api_name} API 요청 중 (시도 {attempt}), URL: {url}, 시간 초과: {timeout}초"

msgid "✅ {api_name} API request successful, Status Code: {code}"
msgstr "✅ {api_name} API 요청 성공, 상태 코드: {code}"

msgid "ℹ️ Telegram returned an ignorable edit/delete type error, ignoring."
msgstr "ℹ️ Telegram에서 무시할 수 있는 수정/삭제 유형의 오류를 반환하여 무시합니다."

msgid "⏳ Telegram rate limit (429), retrying after {seconds}s. Error: {error_text}"
msgstr "⏳ Telegram 요청 제한 (429), {seconds}초 후 재시도합니다. 오류: {error_text}"

msgid "❌ {api_name} server error {code}, will retry. Error: {error_text}"
msgstr "❌ {api_name} 서버 오류 {code}, 재시도합니다. 오류: {error_text}"

msgid "❌ {api_name} API request failed (Attempt {attempt}), Status Code: {code}, Response: {response}"
msgstr "❌ {api_name} API 요청 실패 (시도 {attempt}), 상태 코드: {code}, 응답: {response}"

msgid "❌ Network error on {api_name} API request (Attempt {attempt}), URL: {url}, Error: {error}"
msgstr "❌ {api_name} API 요청 중 네트워크 오류 발생 (시도 {attempt}), URL: {url}, 오류: {error}"

msgid "❌ {api_name} API request failed, max retries reached ({max_retries}), URL: {url}"
msgstr "❌ {api_name} API 요청 실패, 최대 재시도 횟수({max_retries})에 도달했습니다, URL: {url}"

msgid "🔑 Getting Emby Access Token using username/password..."
msgstr "🔑 사용자 이름/비밀번호를 사용하여 Emby 액세스 토큰을 가져오는 중..."

msgid "❌ Missing Emby username or password configuration required to get a token."
msgstr "❌ 토큰을 가져오는 데 필요한 Emby 사용자 이름 또는 비밀번호 구성이 없습니다."

msgid "✅ Successfully obtained Access Token."
msgstr "✅ 액세스 토큰을 성공적으로 가져왔습니다."

msgid "❌ Failed to get Access Token. Status Code: {code}, Response: {text}"
msgstr "❌ 액세스 토큰을 가져오지 못했습니다. 상태 코드: {code}, 응답: {text}"

msgid "❌ Network error while getting Access Token: {error}"
msgstr "❌ 액세스 토큰을 가져오는 중 네트워크 오류가 발생했습니다: {error}"

msgid "🔎 Requesting scan for Emby item ID: {id}, Name: {name}"
msgstr "🔎 Emby 항목 ID: {id}, 이름: {name}에 대한 스캔을 요청하는 중..."

msgid "❌ Scan failed: Emby server configuration is incomplete."
msgstr "❌ 스캔 실패: Emby 서버 구성이 완료되지 않았습니다."

msgid "✅ Scan request sent to Emby for: \"{item_name}\". The process will run in the background. Please check the results in Emby later."
msgstr "✅ \"{item_name}\"에 대한 스캔 요청이 Emby로 전송되었습니다. 이 프로세스는 백그라운드에서 실행됩니다. 나중에 Emby에서 결과를 확인하세요."

msgid "❌ Failed to send scan request for \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ \"{item_name}\"(ID: {item_id})에 대한 스캔 요청을 보내지 못했습니다. 상태 코드: {code}, 서버 응답: {text}"

msgid "🔎 Requesting to scan all Emby libraries..."
msgstr "🔎 모든 Emby 라이브러리 스캔을 요청하는 중..."

msgid "✅ Request to scan all libraries has been sent to Emby. The task will be executed in the background."
msgstr "✅ 모든 라이브러리를 스캔하라는 요청이 Emby로 전송되었습니다. 이 작업은 백그라운드에서 실행됩니다."

msgid "❌ Failed to send \"Scan All\" request. Status Code: {code}, Response: {text}"
msgstr "❌ \"모두 스캔\" 요청을 보내지 못했습니다. 상태 코드: {code}, 응답: {text}"

msgid "🔄 Requesting refresh for Emby item ID: {id}, Name: {name}"
msgstr "🔄 Emby 항목 ID: {id}, 이름: {name}에 대한 새로고침을 요청하는 중..."

msgid "❌ Refresh failed: Emby server configuration is incomplete."
msgstr "❌ 새로고침 실패: Emby 서버 구성이 완료되지 않았습니다."

msgid "✅ Refresh request sent to Emby for: \"{item_name}\". The process will run in the background. Please check the results in Emby later."
msgstr "✅ \"{item_name}\"에 대한 새로고침 요청이 Emby로 전송되었습니다. 이 프로세스는 백그라운드에서 실행됩니다. 나중에 Emby에서 결과를 확인하세요."

msgid "❌ Failed to send refresh request for \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ \"{item_name}\"(ID: {item_id})에 대한 새로고침 요청을 보내지 못했습니다. 상태 코드: {code}, 서버 응답: {text}"

msgid "🗑️ Requesting to delete item from Emby. ID: {id}, Name: {name}"
msgstr "🗑️ Emby에서 항목 삭제를 요청하는 중. ID: {id}, 이름: {name}"

msgid "❌ Failed to delete \"{item_name}\": Could not obtain a valid user Access Token from the Emby server. Please check the username and password in config.yaml."
msgstr "❌ \"{item_name}\" 삭제 실패: Emby 서버에서 유효한 사용자 액세스 토큰을 가져올 수 없습니다. config.yaml에서 사용자 이름과 비밀번호를 확인하세요."

msgid "✅ The item \"{item_name}\" has been successfully deleted from the Emby library."
msgstr "✅ \"{item_name}\" 항목이 Emby 라이브러리에서 성공적으로 삭제되었습니다."

msgid "❌ Failed to delete Emby item \"{item_name}\" (ID: {item_id}). Status Code: {code}, Server Response: {text}"
msgstr "❌ Emby 항목 \"{item_name}\"(ID: {item_id})을(를) 삭제하지 못했습니다. 상태 코드: {code}, 서버 응답: {text}"

msgid "👤 Querying Emby user by username '{username}'..."
msgstr "👤 사용자 이름 '{username}'으로 Emby 사용자 조회 중..."

msgid "Emby server configuration is incomplete."
msgstr "Emby 서버 구성이 완료되지 않았습니다."

msgid "✅ Found user '{username}', ID: {id}"
msgstr "✅ 사용자 '{username}'을(를) 찾았습니다, ID: {id}"

msgid "Could not find a user with the username '{username}'."
msgstr "사용자 이름이 '{username}'인 사용자를 찾을 수 없습니다."

msgid "Could not parse the user list response from Emby."
msgstr "Emby의 사용자 목록 응답을 구문 분석할 수 없습니다."

msgid "Failed to get user list from Emby API."
msgstr "Emby API에서 사용자 목록을 가져오지 못했습니다."

msgid "📜 Getting full info for User ID {id} to extract policy..."
msgstr "📜 정책을 추출하기 위해 사용자 ID {id}의 전체 정보를 가져오는 중..."

msgid "Failed to get user policy: Policy object not found in the returned user data."
msgstr "사용자 정책을 가져오지 못했습니다: 반환된 사용자 데이터에서 정책 개체를 찾을 수 없습니다."

msgid "Failed to get user policy: Could not parse user information returned by the Emby server."
msgstr "사용자 정책을 가져오지 못했습니다: Emby 서버에서 반환한 사용자 정보를 구문 분석할 수 없습니다."

msgid "Failed to get user policy: Could not get user information from the Emby API (please check if template_user_id is correct)."
msgstr "사용자 정책을 가져오지 못했습니다: Emby API에서 사용자 정보를 가져올 수 없습니다 (template_user_id가 올바른지 확인하세요)."

msgid "🔑 Setting a new password for User ID {id}..."
msgstr "🔑 사용자 ID {id}에 대한 새 비밀번호를 설정하는 중..."

msgid "🗑️ Deleting User ID: {id}"
msgstr "🗑️ 사용자 ID 삭제 중: {id}"

msgid "✏️ Renaming username for User ID {id} to '{new_username}'..."
msgstr "✏️ 사용자 ID {id}의 사용자 이름을 '{new_username}'(으)로 변경하는 중..."

msgid "❌ Rename failed: Username '{new_username}' is already taken by another user."
msgstr "❌ 이름 변경 실패: 사용자 이름 '{new_username}'은(는) 이미 다른 사용자가 사용 중입니다."

msgid "❌ Rename failed: Could not get the details of the current user."
msgstr "❌ 이름 변경 실패: 현재 사용자의 세부 정보를 가져올 수 없습니다."

msgid "❌ Rename failed: Could not parse the current user's information."
msgstr "❌ 이름 변경 실패: 현재 사용자의 정보를 구문 분석할 수 없습니다."

msgid "✅ Username has been successfully changed to '{new_username}'."
msgstr "✅ 사용자 이름이 '{new_username}'(으)로 성공적으로 변경되었습니다."

msgid "❌ Failed to rename username, the server did not respond successfully."
msgstr "❌ 사용자 이름을 변경하지 못했습니다. 서버가 성공적으로 응답하지 않았습니다."

msgid "❌ Creation failed: `template_user_id` is not set in the configuration file."
msgstr "❌ 생성 실패: 구성 파일에 `template_user_id`가 설정되어 있지 않습니다."

msgid "❌ Creation failed: Username '{username}' already exists."
msgstr "❌ 생성 실패: 사용자 이름 '{username}'이(가) 이미 존재합니다."

msgid "❌ Creation failed: Could not get the configuration of the template user (ID: {id}). Error: {error}"
msgstr "❌ 생성 실패: 템플릿 사용자(ID: {id})의 구성을 가져올 수 없습니다. 오류: {error}"

msgid "✅ Successfully got the policy for template user {id}."
msgstr "✅ 템플릿 사용자 {id}에 대한 정책을 성공적으로 가져왔습니다."

msgid "➕ Creating new user: {username}..."
msgstr "➕ 새 사용자 생성 중: {username}..."

msgid "❌ Creation failed: Error when calling the Emby API to create a user."
msgstr "❌ 생성 실패: 사용자를 생성하기 위해 Emby API를 호출하는 중 오류가 발생했습니다."

msgid "✅ User '{username}' has been created, new ID: {id}."
msgstr "✅ 사용자 '{username}'이(가) 생성되었습니다, 새 ID: {id}"

msgid "❌ Creation failed: Could not parse new user information from the Emby API response."
msgstr "❌ 생성 실패: Emby API 응답에서 새 사용자 정보를 구문 분석할 수 없습니다."

msgid "📜 Applying template policy for new user {id}..."
msgstr "📜 새 사용자 {id}에게 템플릿 정책을 적용하는 중..."

msgid "❌ Creation failed: Error applying policy for the new user, operation has been rolled back."
msgstr "❌ 생성 실패: 새 사용자에게 정책을 적용하는 중 오류가 발생하여 작업이 롤백되었습니다."

msgid "✅ Policy applied successfully."
msgstr "✅ 정책이 성공적으로 적용되었습니다."

msgid "🔑 Setting password for new user {id}..."
msgstr "🔑 새 사용자 {id}의 비밀번호를 설정하는 중..."

msgid "❌ Creation failed: Error setting password for the new user, operation has been rolled back."
msgstr "❌ 생성 실패: 새 사용자의 비밀번호를 설정하는 중 오류가 발생하여 작업이 롤백되었습니다."

msgid "✅ Password set successfully."
msgstr "✅ 비밀번호가 성공적으로 설정되었습니다."

msgid "✅ Successfully created user '{username}', configuration cloned from template user."
msgstr "✅ 사용자 '{username}'이(가) 성공적으로 생성되었으며, 구성은 템플릿 사용자로부터 복제되었습니다."

msgid "ℹ️ Getting Emby user list from cache."
msgstr "ℹ️ 캐시에서 Emby 사용자 목록을 가져오는 중..."

msgid "🔑 Getting full user list from Emby API..."
msgstr "🔑 Emby API에서 전체 사용자 목록을 가져오는 중..."

msgid "❌ Missing Emby server configuration required to get user list."
msgstr "❌ 사용자 목록을 가져오는 데 필요한 Emby 서버 구성이 없습니다."

msgid "✅ Successfully retrieved and cached {count} usernames."
msgstr "✅ {count}개의 사용자 이름을 성공적으로 검색하고 캐시했습니다."

msgid "❌ Failed to get Emby user list: Could not parse server response."
msgstr "❌ Emby 사용자 목록을 가져오지 못했습니다: 서버 응답을 구문 분석할 수 없습니다."

msgid "❌ Failed to get Emby user list."
msgstr "❌ Emby 사용자 목록을 가져오지 못했습니다."

msgid "ℹ️ Querying active Emby sessions."
msgstr "ℹ️ 활성 Emby 세션을 조회하는 중..."

msgid "❌ Missing Emby server configuration, cannot query sessions."
msgstr "❌ Emby 서버 구성이 없어 세션을 조회할 수 없습니다."

msgid "✅ Found {count} active sessions."
msgstr "✅ {count}개의 활성 세션을 찾았습니다."

msgid "❌ Failed to query active sessions: Could not parse server response."
msgstr "❌ 활성 세션을 조회하지 못했습니다: 서버 응답을 구문 분석할 수 없습니다."

msgid "🛑 Attempting to stop playback session: {id}"
msgstr "🛑 재생 세션 중지 시도 중: {id}"

msgid "❌ Failed to stop session: Emby server configuration is incomplete."
msgstr "❌ 세션 중지 실패: Emby 서버 구성이 완료되지 않았습니다."

msgid "✅ Playback session {id} has been stopped successfully."
msgstr "✅ 재생 세션 {id}이(가) 성공적으로 중지되었습니다."

msgid "❌ Failed to stop playback session {id}."
msgstr "❌ 재생 세션 {id}을(를) 중지하지 못했습니다."

msgid "✉️ Sending message to session {id}."
msgstr "✉️ 세션 {id}에 메시지를 보내는 중..."

msgid "❌ Failed to send message: Emby server configuration is incomplete."
msgstr "❌ 메시지를 보내지 못했습니다: Emby 서버 구성이 완료되지 않았습니다."

msgid "Message from administrator"
msgstr "관리자의 메시지"

msgid "✅ Message sent successfully to session {id}."
msgstr "✅ 메시지가 세션 {id}에 성공적으로 전송되었습니다."

msgid "❌ Failed to send message to session {id}."
msgstr "❌ 세션 {id}에 메시지를 보내지 못했습니다."

msgid "ℹ️ Getting resolution for item {id}."
msgstr "ℹ️ 항목 {id}의 해상도를 가져오는 중..."

msgid "❌ Failed to get media source info for item {id}."
msgstr "❌ 항목 {id}의 미디어 소스 정보를 가져오지 못했습니다."

msgid "Unknown resolution"
msgstr "알 수 없는 해상도"

msgid "❌ Media source for item {id} is empty."
msgstr "❌ 항목 {id}의 미디어 소스가 비어 있습니다."

msgid "✅ Got resolution for item {id}: {w}x{h}"
msgstr "✅ 항목 {id}의 해상도를 가져왔습니다: {w}x{h}"

msgid "⚠️ No video stream found in item {id}."
msgstr "⚠️ 항목 {id}에서 비디오 스트림을 찾을 수 없습니다."

msgid "❌ Error parsing media source info for item {id}."
msgstr "❌ 항목 {id}의 미디어 소스 정보를 구문 분석하는 중 오류가 발생했습니다."

msgid "🗂️ Getting Emby library list..."
msgstr "🗂️ Emby 라이브러리 목록을 가져오는 중..."

msgid "Could not find any media libraries."
msgstr "미디어 라이브러리를 찾을 수 없습니다."

msgid "✅ Successfully retrieved {count} media libraries."
msgstr "✅ {count}개의 미디어 라이브러리를 성공적으로 검색했습니다."

msgid "Failed to parse media library list: {error}"
msgstr "미디어 라이브러리 목록을 구문 분석하지 못했습니다: {error}"

msgid "Failed to get media library list from Emby API."
msgstr "Emby API에서 미디어 라이브러리 목록을 가져오지 못했습니다."

msgid "ℹ️ Getting latest episode information for series {id}."
msgstr "ℹ️ 시리즈 {id}의 최신 에피소드 정보를 가져오는 중..."

msgid "✅ Got latest episode: S{s}E{e}"
msgstr "✅ 최신 에피소드를 가져왔습니다: S{s}E{e}"

msgid "ℹ️ Querying for exact item info of series {id} S{s:02d}E{e:02d}."
msgstr "ℹ️ 시리즈 {id} S{s:02d}E{e:02d}의 정확한 항목 정보를 조회하는 중..."

msgid "✅ Exact match successful, Item ID: {id}"
msgstr "✅ 정확히 일치, 항목 ID: {id}"

msgid "❌ Emby API could not find S{s:02d}E{e:02d}."
msgstr "❌ Emby API가 S{s:02d}E{e:02d}을(를) 찾을 수 없습니다."

msgid "ℹ️ Looking for any episode in season {num} as a spec reference..."
msgstr "ℹ️ 사양 참조를 위해 시즌 {num}의 에피소드를 찾는 중..."

msgid "✅ Found reference episode in season {num}, ID: {id}"
msgstr "✅ 시즌 {num}에서 참조 에피소드를 찾았습니다, ID: {id}"

msgid "❌ Could not find any episodes in season {num}."
msgstr "❌ 시즌 {num}에서 에피소드를 찾을 수 없습니다."

msgid "ℹ️ Getting media stream info for item {id}."
msgstr "ℹ️ 항목 {id}의 미디어 스트림 정보를 가져오는 중..."

msgid "✅ Got media stream info for item {id}."
msgstr "✅ 항목 {id}의 미디어 스트림 정보를 가져왔습니다."

